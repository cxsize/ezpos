{
  "name": "cakethakae-pos",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "seed": "node scripts/seed-catalog.mjs",
    "dev": "docker compose up",
    "dev:device": "docker compose --profile device up emulator seed metro",
    "dev:emulator": "docker compose up emulator",
    "dev:seed": "docker compose run --rm seed",
    "dev:typecheck": "docker compose run --rm typecheck",
    "dev:down": "docker compose down",
    "dev:reset": "docker compose down -v"
  },
  "dependencies": {
    "@expo-google-fonts/bodoni-moda": "*",
    "@expo-google-fonts/inter": "*",
    "@expo-google-fonts/noto-sans-thai": "*",
    "@expo-google-fonts/noto-serif-thai": "*",
    "@expo/metro-runtime": "~4.0.0",
    "@react-native-async-storage/async-storage": "~2.1.0",
    "buffer": "^6.0.3",
    "expo": "~52.0.0",
    "expo-constants": "~17.0.0",
    "expo-crypto": "~14.0.0",
    "expo-dev-client": "~5.0.0",
    "expo-font": "~13.0.0",
    "expo-keep-awake": "~14.0.0",
    "expo-router": "~4.0.0",
    "expo-screen-orientation": "~8.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "firebase": "^10.14.0",
    "nativewind": "^4.1.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.0",
    "react-native-ble-plx": "^3.2.0",
    "react-native-web": "~0.19.13",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "~4.12.0",
    "react-native-screens": "~4.1.0",
    "react-native-svg": "^15.8.0",
    "react-native-worklets": "0.1.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~18.3.12",
    "eslint": "^9.0.0",
