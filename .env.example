# Production Firebase config — leave blank while developing against the local
# emulator (docker compose up emulator metro). Fill these in from the
# Firebase console when you're ready to ship.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Emulator switches — the metro docker service sets these automatically.
# Set EXPO_PUBLIC_USE_FIREBASE_EMULATOR=true to route the app at the local
# Auth + Firestore emulators on EXPO_PUBLIC_FIREBASE_EMULATOR_HOST.
# EXPO_PUBLIC_USE_FIREBASE_EMULATOR=false
# EXPO_PUBLIC_FIREBASE_EMULATOR_HOST=127.0.0.1

# Shop metadata shown on receipts
EXPO_PUBLIC_SHOP_NAME=cakethakae
EXPO_PUBLIC_SHOP_SUBTITLE=เค้กท่าแค
EXPO_PUBLIC_SHOP_ADDRESS=123 ถ.ท่าแค
EXPO_PUBLIC_SHOP_PHONE=02-xxx-xxxx
EXPO_PUBLIC_REGISTER_ID=01
